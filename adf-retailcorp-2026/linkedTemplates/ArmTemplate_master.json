{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-retailcorp-2026"
		},
		"ls_Blob_Storage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_Blob_Storage'"
		},
		"ls_key_vault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-retailcorp-2026.vault.azure.net/"
		},
		"ls_Azure_Sql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "snreatil.database.windows.net"
		},
		"ls_Azure_Sql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "RetailCorpDW"
		},
		"ls_Azure_Sql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminuser"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-retailcorp-2026_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_Blob_Storage_connectionString": {
						"value": "[parameters('ls_Blob_Storage_connectionString')]"
					},
					"ls_key_vault_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_key_vault_properties_typeProperties_baseUrl')]"
					},
					"ls_Azure_Sql_properties_typeProperties_server": {
						"value": "[parameters('ls_Azure_Sql_properties_typeProperties_server')]"
					},
					"ls_Azure_Sql_properties_typeProperties_database": {
						"value": "[parameters('ls_Azure_Sql_properties_typeProperties_database')]"
					},
					"ls_Azure_Sql_properties_typeProperties_userName": {
						"value": "[parameters('ls_Azure_Sql_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}