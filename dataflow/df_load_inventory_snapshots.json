{
	"name": "df_load_inventory_snapshots",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Jsonsnapshort",
						"type": "DatasetReference"
					},
					"name": "srcInventory"
				}
			],
			"sinks": [],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          snapshot_id as string,",
				"          snapshot_date as date,",
				"          warehouse_id as string,",
				"          product_id as string,",
				"          product_name as string,",
				"          category as string,",
				"          qty_on_hand as integer,",
				"          qty_reserved as integer,",
				"          qty_in_transit as integer,",
				"          unit_cost as double,",
				"          total_inventory_value as double,",
				"          days_of_supply as double,",
				"          last_received_date as string,",
				"          reorder_triggered as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments') ~> srcInventory"
			]
		}
	}
}